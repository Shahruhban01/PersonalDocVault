# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/personal_vault

# JWT Secrets
JWT_SECRET=super_secret_access_token_key_change_in_production
REFRESH_JWT_SECRET=super_secret_refresh_token_key_change_in_production

# Cloudflare R2 Configurations (S3-Compatible)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_cloudflare_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_cloudflare_r2_secret_access_key
R2_BUCKET_NAME=personal-vault-production
